{
	"name": "niya",
	"version": "2.0.1",
	"description": "Niya",
	"author": "Nilambar Sharma",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"wordpress-theme"
	],
	"homepage": "https://github.com/ernilambar/niya/",
	"repository": {
		"type": "git",
		"url": "https://github.com/ernilambar/niya/"
	},
	"bugs": {
		"url": "https://github.com/ernilambar/niya/issues"
	},
	"browserslist": "> 1%, last 2 versions, not dead",
	"packtor": {
		"files": [
			"**/*",
			"!*.cjs",
			"!*.js",
			"!*.map",
			"!*.md",
			"!*.lock",
			"!*.yaml",
			"!composer.json",
			"!easy-replace.json",
			"!package.json",
			"!src/**/*",
			"!vendor/**/*"
		]
	},
	"wpDeployer": {
		"repoType": "theme",
		"username": "nilambar",
		"buildDir": "deploy/niya",
		"earlierVersion": "2.0.0"
	},
	"devDependencies": {
		"@wordpress/prettier-config": "^4.42.0",
		"browser-sync": "^3.0.4",
		"easy-replace-in-files": "^2.0.0",
		"gulp": "^5.0.1",
		"gulp-environments": "^1.0.1",
		"gulp-postcss": "^10.0.0",
		"gulp-rename": "^2.1.0",
		"gulp-rtlcss": "^2.0.0",
		"gulp-sourcemaps": "^3.0.0",
		"packtor": "^1.0.4",
		"postcss": "^8.5.8",
		"postcss-custom-media": "^12.0.1",
		"postcss-import": "^16.1.1",
		"postcss-nested": "^7.0.2",
		"postcss-preset-env": "^11.2.0",
		"prettier": "npm:wp-prettier@^3.0.3",
		"rimraf": "^6.1.3",
		"wp-deployer": "^2.0.0"
	},
	"scripts": {
		"predev": "pnpm run build",
		"dev": "gulp",
		"build": "gulp build",
		"prod": "gulp build --env production",
		"pot": "composer run-script pot",
		"format": "prettier \"**/*.{cjs,css,js,json,mjs}\" --write",
		"version": "easy-replace-in-files",
		"clean": "rimraf assets deploy vendor",
		"predeploy": "pnpm run clean && pnpm run prod",
		"deploy": "packtor",
		"prewpdeploy": "pnpm run deploy",
		"wpdeploy": "wp-deployer",
		"wpdeploy:dry-run": "pnpm run deploy && wp-deployer --dry-run"
	}
}
